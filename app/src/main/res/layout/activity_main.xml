<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <!-- Заголовок с тенью для читаемости -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Простая клавиатура"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:shadowColor="#33000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <!-- Остальные элементы остаются с явными цветами -->
        <TextView
            android:id="@+id/instructions_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Основная кнопка -->
        <Button
            android:id="@+id/activate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Активировать клавиатуру"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF" />

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- Инструкция по переключению -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Как переключиться:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Откройте любое поле ввода\n2. Нажмите значок клавиатуры в строке состояния\n3. Выберите 'Простая клавиатура'"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="16dp"
            android:paddingStart="8dp" />

        <!-- Дополнительная секция -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Дополнительные настройки:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Если нужно установить клавиатуру по умолчанию или изменить другие параметры:"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/open_settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Открыть настройки ввода"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

        <!-- Подсказка внизу -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="После активации клавиатура появится в списке способов ввода."
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:background="#F5F5F5" />

    </LinearLayout>
</ScrollView>